# ErgoFlow AI — MongoDB MCP Server Environment Variables
# Copy this to .env for local testing

# ── Required ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MDB_MCP_CONNECTION_STRING=mongodb+srv://admin:admin@ergoai.ofo6lhr.mongodb.net/?appName=ErgoAI

# ── Transport (set to 'http' for remote Agent Builder access) ──────────────
MDB_MCP_TRANSPORT=http
MDB_MCP_HTTP_HOST=0.0.0.0
MDB_MCP_HTTP_PORT=8080

# ── Safety ───────────────────────────────────────────────────────────────────
# Read-only: Agent Builder only queries data. FastAPI handles all writes.
MDB_MCP_READ_ONLY=true
